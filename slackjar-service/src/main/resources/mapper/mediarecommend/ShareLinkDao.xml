<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.slack.slackjarservice.mediarecommend.dao.ShareLinkDao">

    <select id="selectByShareCode" resultType="com.slack.slackjarservice.mediarecommend.entity.ShareLink">
        SELECT * FROM share_link WHERE share_code = #{shareCode} AND deleted = 0
    </select>

    <select id="selectByUserId" resultType="com.slack.slackjarservice.mediarecommend.entity.ShareLink">
        SELECT * FROM share_link WHERE user_id = #{userId} AND deleted = 0 ORDER BY create_time DESC
    </select>

</mapper>