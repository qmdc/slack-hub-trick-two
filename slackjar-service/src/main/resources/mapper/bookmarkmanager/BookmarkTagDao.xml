<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.slack.slackjarservice.bookmarkmanager.dao.BookmarkTagDao">

    <select id="selectByUserId" resultType="com.slack.slackjarservice.bookmarkmanager.entity.BookmarkTag">
        SELECT * FROM bookmark_tag WHERE user_id = #{userId} AND deleted = 0 ORDER BY create_time DESC
    </select>

    <select id="selectByUserIdAndName" resultType="com.slack.slackjarservice.bookmarkmanager.entity.BookmarkTag">
        SELECT * FROM bookmark_tag WHERE user_id = #{userId} AND name = #{name} AND deleted = 0
    </select>

</mapper>