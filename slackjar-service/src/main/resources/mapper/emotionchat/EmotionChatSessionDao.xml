<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.slack.slackjarservice.emotionchat.dao.EmotionChatSessionDao">

    <select id="selectByUserId" resultType="com.slack.slackjarservice.emotionchat.entity.EmotionChatSession">
        SELECT * FROM emotion_chat_session
        WHERE user_id = #{userId} AND deleted = 0
        ORDER BY update_time DESC
    </select>

</mapper>